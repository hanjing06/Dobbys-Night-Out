--- !u!114 &2104093636
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2104093634}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 86382163bdbf229499ebc29775113521, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_description: "Generates 2 Levels of hills one on top of another using Perlin
    noise and a circular mask. Noise mask alone would generate hills across whole
    map which might look unnatural. \n\nWe set the Nose Data to generate wide areas
    of new Hill terrain and apply Circular mask to focus the terrain in the middle
    of the island - simulating some sort of volcano.\n\nWe could apply offse as percent
    of width and height so that the mountain is not always in the center."
  m_applyHills: 1
  m_hillsLevel1AmountModifier: 0.732
  m_hillsLevel2AmountModifier: 0.56
  m_hillsCircularMaskModifier: 0.48
  m_hillsNoiseData: {fileID: 11400000, guid: e0510c2547eb4d54c8c021a2eddbe302, type: 2}
