  m_Script: {fileID: 11500000, guid: 56f22d9019126f744ac78d7e7de65518, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_description: 'Adds trees on top of Ground Tile snad Hills Level1 tiles. TreeTilemap
    generates colliders for them automatically. We are using RuleTile to place trees.
    That is why when we  use SpaceBar to perform Attack and destroy a tree the layout
    changes slightly.


    PalmTrees are places on the SandGrass tiles. It is generated
    using a separate Noise Data to make them more scarse.'
  m_applyTrees: 1
  m_treeNoiseData: {fileID: 11400000, guid: 7ddce92a50ec544439b0668e45c77082, type: 2}
  m_palmTreeData: {fileID: 11400000, guid: ef3d4b941cdb27743815660c11b073de, type: 2}
  m_treeAmount: 0.5
  m_palmTreeAmount: 0.315
