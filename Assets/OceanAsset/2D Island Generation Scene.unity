  m_Script: {fileID: 11500000, guid: 409f46575d7357e48a713421c361e3f2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_description: 'This step will flatten the shalod wea edgeBecause the terrain line
    can be jagged and it looks strange to see the same edge shape where the water
    is.


    We could run this Step before we create the shallow water but this
    and the next step (Flatten Deep Sea) should make both edges look a bit different.'
  m_applyStep: 1
  m_neighborsLimit: 6
  m_tileToFlatten: 2
  m_neighborTilesToDetect: 07000000
  m_tileToSet: 7
