--- !u!114 &1185762940
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1185762938}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bdd4db9bce1982344b9a518785fbdc64, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_description: 'Generates an island map by generating a circular mask and applying
    it onto a map generated using multioctave perlin noise (just because it is already
    implemented in mathf library). This makes the map to have cirecular shape.


    Additional
    Mask applies more details to the circular shape of the map to make it look more
    natrual. It only works if the Island Mask is enabled.


    Island Mask Threshold
    stops working when we enable Additional Mask. To control the circular shape we
    use the SmoothStep From and To parmaeters in that case.'
  m_applyBaseTerrain: 1
  m_applyIslandMask: 1
  m_applyAdditionalIslandMask: 1
  m_waterThreshold: 0.2
  m_hillsThreshold: 0.7
  m_islandMaskThreshold: 0.5
  m_islandAdditionalMaskThreshold: 0.09
  m_islandSmoothStepFrom: 0
  m_islandSmoothStepTo: 0.525
  m_noiseData: {fileID: 11400000, guid: 2c953a4c18c652d4e941bb9e1ace0766, type: 2}
  m_islandNoiseData: {fileID: 11400000, guid: 1a5c0788d3dbee94bbef513defe5f5de, type: 2}
