  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 890930f029a6dab4186bff93a63099b1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_description: "To ensure that we can go up and down the Hills we will use the
    result of MapSeparateHillsStep and A* pathfinding to generate paths from any
    \"inner\" tile of each hill to one of the edges of the map. \n\nThis way each
    hill has a stair case and non of them is blocked by Water or Trees."
  m_applyStep: 1
  m_mapEdges: []
  m_hill1PathObstacleTypes: 0100000005000000
  m_hill1PathSubstituteTypes: 03000000
  m_hill2PathObstacleTypes: 01000000
  m_hill2PathSubstituteTypes: 0300000004000000
  colors: []
